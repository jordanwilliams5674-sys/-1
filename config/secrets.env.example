# Beidou local secrets template
#
# Copy this file to config/secrets.env only on your local machine.
# Never commit config/secrets.env.
# Leave values blank unless a local script explicitly needs that provider.

# Market data / event APIs
FINNHUB_API_KEY=
POLYGON_API_KEY=
MASSIVE_API_KEY=
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=

# Optional research data provider
QUIVER_API_KEY=

# Optional mobile notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PUSHPLUS_TOKEN=
SERVERCHAN_SENDKEY=

# Optional email notifications
PREMARKET_EMAIL_TO=
PREMARKET_EMAIL_FROM=
PREMARKET_SMTP_HOST=
PREMARKET_SMTP_PORT=
PREMARKET_SMTP_USER=
PREMARKET_SMTP_PASSWORD=
