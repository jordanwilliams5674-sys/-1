# 北斗本地密钥模板。
# 复制为 config/secrets.env 后填写真实值。不要把 secrets.env 发给别人。

# 行情 / 异动 API，三选一或多选。
FINNHUB_API_KEY=
POLYGON_API_KEY=
MASSIVE_API_KEY=
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=

# Quiver Quant，选填。
QUIVER_API_KEY=

# 手机通知，二选一或多选。
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PUSHPLUS_TOKEN=
SERVERCHAN_SENDKEY=

# 邮件通知，QQ 邮箱需要 SMTP 授权码，不是 QQ 登录密码。
PREMARKET_EMAIL_TO=295765031@qq.com
PREMARKET_EMAIL_FROM=295765031@qq.com
PREMARKET_SMTP_HOST=smtp.qq.com
PREMARKET_SMTP_PORT=465
PREMARKET_SMTP_USER=295765031@qq.com
PREMARKET_SMTP_PASSWORD=
